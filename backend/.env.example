# HYLATOR BACKEND PRODUCTION CONFIGURATION
# ----------------------------------------
# Instructions:
# 1. Rename this file from `.env.example` to `.env`
# 2. Fill in the values below with your production server details.

# 1. SECURITY KEY (Crucial!)
# Generate a strong, random string to encrypt user JWT tokens.
# Do NOT use the default development key in production.
HYBRID_SECRET_KEY="replace_me_with_a_secure_random_string_in_production"

# 2. DATABASE CONFIGURATION
# By default, the app uses a local SQLite file (translator_app.db).
# On cloud hosts (Render, Heroku), this file gets deleted every time the server restarts.
# You MUST use a persistent database like PostgreSQL for production.
# Example PostgreSQL URL: postgresql://username:password@hostname:port/dbname
DATABASE_URL="postgresql://user:password@cloud-database-provider.com:5432/hylator_db"
